# Required
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=./secrets/github-app.pem
GITHUB_WEBHOOK_SECRET=
ANTHROPIC_API_KEY=
SIGNAL_INGESTION_HMAC_SECRET=

# Deployment webhook (required if using deployment orchestration)
DEPLOYMENT_WEBHOOK_URL=
DEPLOYMENT_WEBHOOK_SECRET=

# Optional (auto-generated or sensible defaults if empty)
DASHBOARD_AUTH_TOKEN=
ALLOWED_ORIGINS=http://localhost:3001
DATABASE_URL=postgresql://pullmint:pullmint@localhost:5432/pullmint
REDIS_URL=redis://localhost:6379
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
LOG_LEVEL=info