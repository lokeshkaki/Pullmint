# Required
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=./secrets/github-app.pem
GITHUB_WEBHOOK_SECRET=
ANTHROPIC_API_KEY=
# LLM Provider (default: anthropic). Future: openai, google
LLM_PROVIDER=anthropic
SIGNAL_INGESTION_HMAC_SECRET=

# Deployment webhook (required if using deployment orchestration)
DEPLOYMENT_WEBHOOK_URL=
DEPLOYMENT_WEBHOOK_SECRET=

# Optional (auto-generated or sensible defaults if empty)
DASHBOARD_AUTH_TOKEN=
ALLOWED_ORIGINS=http://localhost:3001
DATABASE_URL=postgresql://pullmint:pullmint@localhost:5432/pullmint
REDIS_URL=redis://localhost:6379
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
LOG_LEVEL=info

# Incremental analysis threshold (0-1, default 0.5)
# If more than this fraction of files changed on force-push, full re-analysis runs
# INCREMENTAL_ANALYSIS_THRESHOLD=0.5

# LLM model overrides (per agent)
# LLM_ARCHITECTURE_MODEL=claude-sonnet-4-6
# LLM_SECURITY_MODEL=claude-sonnet-4-6
# LLM_PERFORMANCE_MODEL=claude-haiku-4-5-20251001
# LLM_MAINTAINABILITY_MODEL=claude-haiku-4-5-20251001