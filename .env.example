# Required
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=./secrets/github-app.pem
GITHUB_WEBHOOK_SECRET=
ANTHROPIC_API_KEY=

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Which LLM provider to use. Options: anthropic (default), openai, google
LLM_PROVIDER=anthropic

# Anthropic (default provider)
# ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI (set LLM_PROVIDER=openai)
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_BASE_URL=                         # Optional: override API base URL
#                                          # e.g. http://localhost:11434/v1 for Ollama
#                                          #      https://<resource>.openai.azure.com/...

# Google Gemini (set LLM_PROVIDER=google)
# GOOGLE_API_KEY=your-google-api-key

SIGNAL_INGESTION_HMAC_SECRET=

# Deployment webhook (required if using deployment orchestration)
DEPLOYMENT_WEBHOOK_URL=
DEPLOYMENT_WEBHOOK_SECRET=

# Optional (auto-generated or sensible defaults if empty)
DASHBOARD_AUTH_TOKEN=
ALLOWED_ORIGINS=http://localhost:3001
DATABASE_URL=postgresql://pullmint:pullmint@localhost:5432/pullmint
REDIS_URL=redis://localhost:6379
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
LOG_LEVEL=info

# Incremental analysis threshold (0-1, default 0.5)
# If more than this fraction of files changed on force-push, full re-analysis runs
# INCREMENTAL_ANALYSIS_THRESHOLD=0.5

# ─── Agent Model Overrides ────────────────────────────────────────────────────
# Override the model used per agent. Defaults are Anthropic model IDs.
# When switching provider, set these to the appropriate model IDs for that provider.
#
# Anthropic defaults:
# LLM_ARCHITECTURE_MODEL=claude-sonnet-4-6
# LLM_SECURITY_MODEL=claude-sonnet-4-6
# LLM_PERFORMANCE_MODEL=claude-haiku-4-5-20251001
# LLM_MAINTAINABILITY_MODEL=claude-haiku-4-5-20251001
#
# OpenAI examples:
# LLM_ARCHITECTURE_MODEL=gpt-4o
# LLM_SECURITY_MODEL=gpt-4o
# LLM_PERFORMANCE_MODEL=gpt-4o-mini
# LLM_MAINTAINABILITY_MODEL=gpt-4o-mini
#
# Google Gemini examples:
# LLM_ARCHITECTURE_MODEL=gemini-1.5-pro
# LLM_SECURITY_MODEL=gemini-1.5-pro
# LLM_PERFORMANCE_MODEL=gemini-1.5-flash
# LLM_MAINTAINABILITY_MODEL=gemini-1.5-flash