{
  "name": "@pullmint/action",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Action entry point for Pullmint PR analysis",
  "scripts": {
    "build": "ncc build src/main.ts -o dist --minify --source-map",
    "build:dev": "ncc build src/main.ts -o dist --source-map",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@anthropic-ai/sdk": "^0.56.0",
    "@google/generative-ai": "^0.24.0",
    "@octokit/rest": "^21.0.0",
    "openai": "^4.77.0",
    "picomatch": "^4.0.4",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^25.5.0",
    "@types/picomatch": "^4.0.2",
    "@vercel/ncc": "^0.38.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.3.3"
  }
}