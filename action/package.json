{
  "name": "@pullmint/action",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "description": "GitHub Action entry point for Pullmint PR analysis",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --minify --sourcemap",
    "build:dev": "esbuild src/main.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --sourcemap",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@anthropic-ai/sdk": "^0.56.0",
    "@google/generative-ai": "^0.24.0",
    "@octokit/rest": "^21.0.0",
    "lodash": "^4.18.1",
    "openai": "^6.36.0",
    "picomatch": "^4.0.4",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^25.5.0",
    "@types/picomatch": "^4.0.2",
    "esbuild": "^0.25.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.3.3"
  }
}
