---
const steps = [
  {
    number: '01',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"></path></svg>`,
    color: 'text-blue-400 bg-blue-500/10',
    title: 'PR Opened',
    description:
      'GitHub webhook fires instantly. Pullmint fetches the diff, checks per-repo config, and validates dedup before queueing.',
  },
  {
    number: '02',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"></path></svg>`,
    color: 'text-emerald-400 bg-emerald-500/10',
    title: '4 Agents Analyze',
    description:
      'Architecture, security, performance, and style agents run in parallel via BullMQ. Each gets a filtered slice of the diff relevant only to its domain.',
  },
  {
    number: '03',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"></path></svg>`,
    color: 'text-amber-400 bg-amber-500/10',
    title: 'Risk Scored',
    description:
      'A synthesizer collects all findings, deduplicates them via Levenshtein distance, and produces a 0-100 risk score weighted by learned signal weights.',
  },
  {
    number: '04',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"></path></svg>`,
    color: 'text-blue-400 bg-blue-500/10',
    title: 'Review Posted',
    description:
      'GitHub review is created with inline comments anchored to exact diff lines. High-risk PRs can trigger Slack, Discord, or Teams alerts or block merge.',
  },
];
---

<section id="how-it-works" class="bg-navy-800/50 px-6 py-24">
  <div class="mx-auto max-w-7xl">
    <div class="mb-16 text-center">
      <h2 class="mb-4 text-4xl font-bold text-white">From Webhook to Review in Under 30 Seconds</h2>
      <p class="mx-auto max-w-2xl text-lg text-slate-400">
        Every PR gets the same expert panel. The pipeline is fully asynchronous - your CI never waits.
      </p>
    </div>

    <div class="hidden items-start gap-0 lg:flex">
      {steps.map((step, index) => (
        <>
          <div class="flex-1 text-center">
            <div class={`mb-4 inline-flex h-16 w-16 items-center justify-center rounded-2xl border border-current/20 ${step.color}`} set:html={step.icon} />
            <div class="mb-1 font-mono text-xs text-slate-600">{step.number}</div>
            <h3 class="mb-2 font-semibold text-white">{step.title}</h3>
            <p class="mx-auto max-w-[200px] text-sm leading-relaxed text-slate-400">{step.description}</p>
          </div>
          {index < steps.length - 1 && (
            <div class="flex flex-none items-start px-2 pt-8">
              <svg width="60" height="2" class="mt-4 overflow-visible" aria-hidden="true">
                <line
                  x1="0"
                  y1="1"
                  x2="60"
                  y2="1"
                  stroke="#475569"
                  stroke-width="2"
                  stroke-dasharray="6 4"
                  stroke-dashoffset="0"
                  style="animation: dash 1.5s linear infinite;"
                ></line>
              </svg>
            </div>
          )}
        </>
      ))}
    </div>

    <div class="space-y-8 lg:hidden">
      {steps.map((step) => (
        <div class="flex gap-4">
          <div class={`inline-flex h-12 w-12 flex-none items-center justify-center rounded-xl ${step.color}`} set:html={step.icon} />
          <div>
            <div class="mb-0.5 font-mono text-xs text-slate-600">{step.number}</div>
            <h3 class="mb-1 font-semibold text-white">{step.title}</h3>
            <p class="text-sm leading-relaxed text-slate-400">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes dash {
    to {
      stroke-dashoffset: -20;
    }
  }
</style>