---
export interface Props {
  iconSrc: string;
}

const { iconSrc } = Astro.props;
---

<section id="demo" class="px-6 py-24">
  <div class="mx-auto max-w-7xl">
    <div class="mb-16 text-center">
      <h2 class="mb-4 text-4xl font-bold text-white">What Your PR Actually Gets</h2>
      <p class="mx-auto max-w-2xl text-lg text-slate-400">
        Inline comments anchored to the lines that matter. Not a comment at the top - a finding exactly where the problem is.
      </p>
    </div>

    <div class="mx-auto max-w-4xl overflow-hidden rounded-xl border border-[#30363d] bg-[#0d1117] font-mono text-sm shadow-2xl">
      <div class="flex items-center gap-3 border-b border-[#30363d] px-6 py-4">
        <svg class="h-5 w-5 text-emerald-400" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M16.5 4.478v.227a48.816 48.816 0 013.878.512.75.75 0 11-.256 1.478l-.209-.035-1.005 13.07a3 3 0 01-2.991 2.77H8.084a3 3 0 01-2.991-2.77L4.087 6.66l-.209.035a.75.75 0 01-.256-1.478A48.567 48.567 0 017.5 4.705v-.227c0-1.564 1.213-2.9 2.816-2.951a52.662 52.662 0 013.369 0c1.603.051 2.815 1.387 2.815 2.951zm-6.136-1.452a51.196 51.196 0 013.273 0C14.39 3.05 15 3.684 15 4.478v.113a49.488 49.488 0 00-6 0v-.113c0-.794.609-1.428 1.364-1.452zm-.355 5.945a.75.75 0 10-1.5.058l.347 9a.75.75 0 101.499-.058l-.346-9zm5.48.058a.75.75 0 10-1.498-.058l-.347 9a.75.75 0 001.5.058l.345-9z" clip-rule="evenodd"></path>
        </svg>
        <span class="font-sans text-base font-semibold text-[#e6edf3]">Refactor auth middleware to use JWT validation</span>
        <span class="ml-auto rounded-full border border-emerald-600/40 bg-emerald-900/50 px-2.5 py-0.5 font-sans text-xs text-emerald-400">Open</span>
      </div>

      <div class="flex items-center gap-2 border-b border-[#30363d] bg-[#161b22] px-4 py-2 font-sans text-xs text-[#8b949e]">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"></path>
        </svg>
        src/middleware/auth.ts
        <span class="ml-auto text-emerald-400">+47</span>
        <span class="text-rose-400">-12</span>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-xs">
          <tbody>
            <tr class="bg-[#0d1117]">
              <td class="w-10 select-none px-3 py-0.5 text-right text-[#484f58]">12</td>
              <td class="w-10 select-none px-3 py-0.5 text-right text-[#484f58]">12</td>
              <td class="px-4 py-0.5 text-[#8b949e]">
                <span class="text-[#8b949e]">export async function verifyToken(req: Request): Promise&lt;User&gt; &#123;</span>
              </td>
            </tr>
            <tr class="bg-[#161b22]">
              <td class="select-none px-3 py-0.5 text-right text-[#484f58]"></td>
              <td class="select-none px-3 py-0.5 text-right text-[#484f58]">13</td>
              <td class="bg-emerald-900/20 px-4 py-0.5 text-emerald-300">+&nbsp;&nbsp;const token = req.headers.authorization?.split(' ')[1];</td>
            </tr>
            <tr class="bg-[#161b22]">
              <td class="select-none px-3 py-0.5 text-right text-[#484f58]"></td>
              <td class="select-none px-3 py-0.5 text-right text-[#484f58]">14</td>
              <td class="bg-emerald-900/20 px-4 py-0.5 text-emerald-300">+&nbsp;&nbsp;if (!token) throw new Error('Missing token');</td>
            </tr>
            <tr class="bg-[#161b22]">
              <td class="select-none px-3 py-0.5 text-right text-[#484f58]"></td>
              <td class="select-none px-3 py-0.5 text-right text-[#484f58]">15</td>
              <td class="bg-emerald-900/20 px-4 py-0.5 text-emerald-300">+&nbsp;&nbsp;return jwt.verify(token, process.env.JWT_SECRET) as User;</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="border-y border-[#30363d] bg-[#161b22] px-4 py-4">
        <div class="flex items-start gap-3">
          <div class="flex h-8 w-8 flex-none items-center justify-center rounded-full border border-navy-600 bg-navy-700">
            <img src={iconSrc} alt="Pullmint bot" class="h-5 w-5" />
          </div>
          <div class="min-w-0 flex-1">
            <div class="mb-2 flex flex-wrap items-center gap-2">
              <span class="font-sans text-sm font-semibold text-[#e6edf3]">pullmint[bot]</span>
              <span class="font-sans text-xs text-[#8b949e]">just now</span>
              <span class="ml-auto flex flex-wrap items-center gap-1.5">
                <span class="rounded-full border border-amber-500/30 bg-amber-500/15 px-2 py-0.5 font-sans text-xs font-medium text-amber-400">security · high</span>
                <span class="rounded-full border border-blue-500/30 bg-blue-500/15 px-2 py-0.5 font-sans text-xs font-medium text-blue-400">new</span>
              </span>
            </div>
            <div class="font-sans text-sm leading-relaxed text-[#c9d1d9]">
              <p class="mb-1 font-semibold text-amber-300">Hardcoded fallback risks undefined secret exposure</p>
              <p><code class="rounded bg-[#0d1117] px-1.5 py-0.5 text-xs text-rose-300">process.env.JWT_SECRET</code> is not validated for presence before being passed to <code class="rounded bg-[#0d1117] px-1.5 py-0.5 text-xs">jwt.verify()</code>. If <code class="rounded bg-[#0d1117] px-1.5 py-0.5 text-xs text-rose-300">JWT_SECRET</code> is undefined, the JWT library may silently accept unsigned tokens depending on version.</p>
              <p class="mt-2 text-[#8b949e]">
                <strong class="text-[#c9d1d9]">Suggestion:</strong> Add <code class="rounded bg-[#0d1117] px-1.5 py-0.5 text-xs">if (!process.env.JWT_SECRET) throw new Error('JWT_SECRET not configured');</code> at startup, or use a config guard that fails fast.
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="border-b border-[#30363d] bg-[#161b22] px-4 py-4">
        <div class="flex items-start gap-3">
          <div class="flex h-8 w-8 flex-none items-center justify-center rounded-full border border-navy-600 bg-navy-700">
            <img src={iconSrc} alt="Pullmint bot" class="h-5 w-5" />
          </div>
          <div class="min-w-0 flex-1">
            <div class="mb-2 flex flex-wrap items-center gap-2">
              <span class="font-sans text-sm font-semibold text-[#e6edf3]">pullmint[bot]</span>
              <span class="font-sans text-xs text-[#8b949e]">just now</span>
              <span class="ml-auto flex items-center gap-1.5">
                <span class="rounded-full border border-slate-500/30 bg-slate-500/15 px-2 py-0.5 font-sans text-xs font-medium text-slate-400">architecture · medium</span>
                <span class="rounded-full border border-emerald-500/30 bg-emerald-500/15 px-2 py-0.5 font-sans text-xs font-medium text-emerald-400">persisted</span>
              </span>
            </div>
            <div class="font-sans text-sm leading-relaxed text-[#c9d1d9]">
              <p class="mb-1 font-semibold text-slate-200">Auth logic leaking into transport layer</p>
              <p>Token extraction and JWT verification are co-located in middleware that also handles request parsing. This tightly couples authentication logic to Express internals - consider extracting a pure <code class="rounded bg-[#0d1117] px-1.5 py-0.5 text-xs">TokenService.verify(token: string)</code> that middleware delegates to.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="flex flex-wrap items-center gap-4 border-t border-[#30363d] bg-[#161b22] px-6 py-4 font-sans text-sm">
        <div class="flex items-center gap-2">
          <span class="text-[#8b949e]">Risk score:</span>
          <span class="text-lg font-bold text-amber-400">58</span>
          <span class="text-[#8b949e]">/ 100</span>
        </div>
        <div class="h-4 w-px bg-[#30363d]"></div>
        <div class="flex items-center gap-2 text-[#8b949e]">
          <span class="h-2 w-2 rounded-full bg-rose-500"></span> 1 high
          <span class="ml-2 h-2 w-2 rounded-full bg-amber-500"></span> 2 medium
          <span class="ml-2 h-2 w-2 rounded-full bg-slate-500"></span> 3 low
        </div>
        <div class="ml-auto text-xs text-[#8b949e]">Analyzed 12 files · 4 agents · 3.1s</div>
      </div>
    </div>

    <div class="mt-10 text-center">
      <a href="#quickstart" class="inline-flex items-center gap-2 font-medium text-blue-400 transition-colors hover:text-blue-300">
        Set this up for your team
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
        </svg>
      </a>
    </div>
  </div>
</section>