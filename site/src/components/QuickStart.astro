---
const actionYaml = `name: Pullmint PR Review
on:
  pull_request:

jobs:
  review:
    runs-on: ubuntu-latest
    steps:
      - uses: lokeshkaki/pullmint@v1
        with:
          anthropic-api-key: \${{ secrets.ANTHROPIC_API_KEY }}`;

const dockerBash = `git clone https://github.com/lokeshkaki/pullmint
cp .env.example .env  # fill in API keys + GitHub App credentials
docker compose up -d`;
---

<section id="quickstart" class="bg-navy-800/50 px-6 py-24">
  <div class="mx-auto max-w-3xl">
    <div class="mb-12 text-center">
      <h2 class="mb-4 text-4xl font-bold text-white">Up and Running in Minutes</h2>
      <p class="text-lg text-slate-400">Pick the deployment mode that fits your team. Switch anytime.</p>
    </div>

    <div class="quickstart-tabs">
      <div class="mb-0 flex border-b border-navy-700">
        <a href="#tab-action" class="quickstart-tab quickstart-tab-action border-b-2 border-transparent px-6 py-3 text-sm font-medium text-slate-400 transition-all hover:border-slate-600 hover:text-white">
          GitHub Action
        </a>
        <a href="#tab-selfhosted" class="quickstart-tab quickstart-tab-selfhosted border-b-2 border-transparent px-6 py-3 text-sm font-medium text-slate-400 transition-all hover:border-slate-600 hover:text-white">
          Self-Hosted
        </a>
      </div>

      <div id="tab-action" class="quickstart-panel quickstart-panel-action block">
        <div class="overflow-hidden rounded-b-2xl rounded-tr-2xl border border-navy-700 bg-navy-900">
          <div class="flex items-center gap-2 border-b border-navy-700 bg-navy-800 px-4 py-3">
            <div class="flex gap-1.5">
              <span class="h-3 w-3 rounded-full bg-navy-600"></span>
              <span class="h-3 w-3 rounded-full bg-navy-600"></span>
              <span class="h-3 w-3 rounded-full bg-navy-600"></span>
            </div>
            <span class="ml-2 font-mono text-xs text-slate-500">.github/workflows/pullmint.yml</span>
          </div>
          <pre class="overflow-x-auto p-6 font-mono text-sm leading-relaxed text-slate-300"><code>{actionYaml}</code></pre>
        </div>
        <div class="mt-4 flex items-start gap-3 rounded-xl border border-emerald-800/40 bg-emerald-900/20 p-4">
          <svg class="mt-0.5 h-5 w-5 flex-none text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <p class="text-sm text-slate-300">No server or database needed. Analysis runs inside the GitHub Actions runner. Results post directly to the PR. Add <code class="rounded bg-navy-700 px-1.5 py-0.5 text-xs">OPENAI_API_KEY</code> or <code class="rounded bg-navy-700 px-1.5 py-0.5 text-xs">GOOGLE_API_KEY</code> to switch providers.</p>
        </div>
      </div>

      <div id="tab-selfhosted" class="quickstart-panel quickstart-panel-selfhosted hidden">
        <div class="overflow-hidden rounded-b-2xl rounded-tr-2xl border border-navy-700 bg-navy-900">
          <div class="flex items-center gap-2 border-b border-navy-700 bg-navy-800 px-4 py-3">
            <div class="flex gap-1.5">
              <span class="h-3 w-3 rounded-full bg-navy-600"></span>
              <span class="h-3 w-3 rounded-full bg-navy-600"></span>
              <span class="h-3 w-3 rounded-full bg-navy-600"></span>
            </div>
            <span class="ml-2 font-mono text-xs text-slate-500">terminal</span>
          </div>
          <pre class="overflow-x-auto p-6 font-mono text-sm leading-relaxed text-slate-300"><code>{dockerBash}</code></pre>
        </div>
        <div class="mt-4 flex items-start gap-3 rounded-xl border border-blue-800/40 bg-blue-900/20 p-4">
          <svg class="mt-0.5 h-5 w-5 flex-none text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <p class="text-sm text-slate-300">Runs PostgreSQL, Redis, MinIO, Fastify API, and BullMQ workers via Docker Compose. Dashboard available at <code class="rounded bg-navy-700 px-1.5 py-0.5 text-xs">http://localhost</code> after startup.</p>
        </div>
      </div>
    </div>

    <div class="mt-10 text-center">
      <a
        href="https://github.com/lokeshkaki/pullmint/blob/main/README.md"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-slate-400 underline underline-offset-4 transition-colors hover:text-white"
      >
        Read the full setup guide →
      </a>
    </div>
  </div>
</section>

<style>
  .quickstart-tabs .quickstart-tab-action {
    border-color: rgb(59 130 246 / 1);
    color: rgb(96 165 250 / 1);
  }

  .quickstart-tabs:has(#tab-selfhosted:target) .quickstart-panel-action {
    display: none;
  }

  .quickstart-tabs:has(#tab-selfhosted:target) .quickstart-panel-selfhosted {
    display: block;
  }

  .quickstart-tabs:has(#tab-selfhosted:target) .quickstart-tab-action {
    border-color: transparent;
    color: rgb(148 163 184 / 1);
  }

  .quickstart-tabs:has(#tab-selfhosted:target) .quickstart-tab-selfhosted {
    border-color: rgb(59 130 246 / 1);
    color: rgb(96 165 250 / 1);
  }
</style>