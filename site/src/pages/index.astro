---
import ComparisonTable from '../components/ComparisonTable.astro';
import ConfigExample from '../components/ConfigExample.astro';
import DemoSection from '../components/DemoSection.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import Footer from '../components/Footer.astro';
import HowItWorks from '../components/HowItWorks.astro';
import PerformanceSection from '../components/PerformanceSection.astro';
import QuickStart from '../components/QuickStart.astro';
import Layout from '../layouts/Layout.astro';

const basePath = import.meta.env.BASE_URL;
const withBase = (path: string) => `${basePath}${path.replace(/^\/+/, '')}`;
const terminalLines = [
  { tone: 'text-slate-500', text: '$ pullmint analyze --pr 142' },
  { tone: 'text-blue-400', text: '→ Fetching diff (847 lines across 12 files)' },
  { tone: 'text-slate-400', text: '⟳ Architecture agent', accent: '✓ done (1.2s)' },
  { tone: 'text-slate-400', text: '⟳ Security agent', accent: '✓ done (1.4s)' },
  { tone: 'text-slate-400', text: '⟳ Performance agent', accent: '✓ done (0.9s)' },
  { tone: 'text-slate-400', text: '⟳ Style agent', accent: '✓ done (0.8s)' },
  { tone: 'font-semibold text-amber-400', text: '→ Risk score: 42 / 100  (medium)' },
  { tone: 'text-slate-400', text: '8 findings: 1 high · 3 medium · 4 low' },
  { tone: 'text-emerald-400', text: '✓ Posted 7 inline comments on PR #142' },
];
---

<Layout>
  <header class="fixed inset-x-0 top-0 z-50 border-b border-navy-700/50 bg-navy-900/80 backdrop-blur">
    <nav class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6" aria-label="Primary navigation">
      <a href={basePath} class="flex items-center gap-2 text-lg font-semibold">
        <img src={withBase('favicon.svg')} alt="" class="h-7 w-7" />
        <span class="text-white">Pullmint</span>
      </a>
      <div class="hidden items-center gap-8 text-sm text-slate-400 md:flex">
        <a href="#features" class="transition-colors hover:text-white">Features</a>
        <a href="#how-it-works" class="transition-colors hover:text-white">How It Works</a>
        <a href="#demo" class="transition-colors hover:text-white">Demo</a>
        <a href="#quickstart" class="transition-colors hover:text-white">Quick Start</a>
      </div>
      <a
        href="https://github.com/lokeshkaki/pullmint"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 rounded-lg border border-navy-600 bg-navy-700 px-4 py-2 text-sm transition-colors hover:bg-navy-600"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"></path>
        </svg>
        GitHub
      </a>
    </nav>
  </header>

  <section class="relative overflow-hidden px-6 pb-24 pt-32">
    <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="absolute -right-40 -top-40 h-[600px] w-[600px] rounded-full bg-blue-500/10 blur-3xl"></div>
      <div class="absolute -bottom-20 -left-40 h-[500px] w-[500px] rounded-full bg-emerald-500/10 blur-3xl"></div>
    </div>

    <div class="relative mx-auto max-w-7xl">
      <div class="max-w-3xl">
        <div class="mb-8 inline-flex items-center gap-2 rounded-full border border-blue-500/20 bg-blue-500/10 px-4 py-1.5 text-sm text-blue-400">
          <span class="h-2 w-2 animate-pulse-slow rounded-full bg-emerald-400"></span>
          Open source · Self-hosted · GitHub Action
        </div>

        <h1 class="mb-6 text-5xl font-bold leading-tight text-white md:text-6xl">
          AI-Powered PR Reviews That Actually
          <span class="text-blue-400"> Understand Your Code</span>
        </h1>

        <p class="mb-10 max-w-2xl text-xl leading-relaxed text-slate-400">
          4 specialized agents analyze architecture, security, performance, and style - then post inline review comments right on your PR. Risk-scored, lifecycle-tracked, and learning from every deployment.
        </p>

        <div class="mb-16 flex flex-wrap gap-4">
          <a
            href="#quickstart"
            class="inline-flex items-center gap-2 rounded-xl bg-blue-500 px-8 py-3.5 font-semibold text-white shadow-lg shadow-blue-500/20 transition-colors hover:bg-blue-600"
          >
            Get Started
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </a>
          <a
            href="#demo"
            class="inline-flex items-center gap-2 rounded-xl border border-navy-600 bg-navy-700 px-8 py-3.5 font-semibold text-slate-200 transition-colors hover:bg-navy-600"
          >
            View Demo
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </a>
        </div>

        <div class="flex items-center gap-3 text-sm text-slate-500">
          <a
            href="https://github.com/lokeshkaki/pullmint/stargazers"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-1.5 transition-colors hover:text-slate-300"
          >
            <svg class="h-4 w-4 text-amber-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
            </svg>
            Star on GitHub
          </a>
          <span>·</span>
          <a
            href="https://github.com/lokeshkaki/pullmint/blob/main/LICENSE"
            target="_blank"
            rel="noopener noreferrer"
            class="transition-colors hover:text-slate-300"
          >
            MIT License
          </a>
        </div>
      </div>

      <div class="mt-16 max-w-2xl">
        <div class="overflow-hidden rounded-2xl border border-navy-600 bg-navy-800 shadow-2xl">
          <div class="flex items-center gap-2 border-b border-navy-600 bg-navy-700 px-4 py-3">
            <span class="h-3 w-3 rounded-full bg-rose-500"></span>
            <span class="h-3 w-3 rounded-full bg-amber-500"></span>
            <span class="h-3 w-3 rounded-full bg-emerald-500"></span>
            <span class="ml-2 font-mono text-xs text-slate-500">pullmint · PR #142</span>
          </div>
          <div class="hero-terminal space-y-2 p-5 font-mono text-sm leading-relaxed">
            {terminalLines.map((line) => (
              <p class={`hero-terminal-line ${line.tone}`}>
                {line.text}
                {line.accent && <span class="ml-4 text-emerald-400">{line.accent}</span>}
              </p>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <FeatureGrid />
  <HowItWorks />
  <PerformanceSection />
  <DemoSection iconSrc={withBase('favicon.svg')} />
  <ConfigExample />
  <ComparisonTable />
  <QuickStart />
  <Footer iconSrc={withBase('favicon.svg')} />
</Layout>

<style is:global>
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-terminal-line {
    opacity: 0;
    animation: fadeUp 0.4s ease-out both;
  }

  .hero-terminal-line:nth-child(1) {
    animation-delay: 0.1s;
  }

  .hero-terminal-line:nth-child(2) {
    animation-delay: 0.4s;
  }

  .hero-terminal-line:nth-child(3) {
    animation-delay: 0.7s;
  }

  .hero-terminal-line:nth-child(4) {
    animation-delay: 0.9s;
  }

  .hero-terminal-line:nth-child(5) {
    animation-delay: 1.1s;
  }

  .hero-terminal-line:nth-child(6) {
    animation-delay: 1.3s;
  }

  .hero-terminal-line:nth-child(7) {
    animation-delay: 1.6s;
  }

  .hero-terminal-line:nth-child(8) {
    animation-delay: 1.9s;
  }

  .hero-terminal-line:nth-child(9) {
    animation-delay: 2.2s;
  }
</style>