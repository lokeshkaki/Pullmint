{
  "name": "@pullmint/shared",
  "version": "0.1.0",
  "description": "Shared utilities for Pullmint services",
  "private": true,
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./diff-filter": "./dist/diff-filter.js",
    "./dedup": "./dist/dedup.js",
    "./prompts/*": "./dist/prompts/*.js",
    "./*": "./dist/*.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "bullmq": "^5.71.0",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.10.1",
    "octokit": "^5.0.5",
    "picomatch": "^4.0.4",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^25.5.0",
    "@types/picomatch": "^4.0.2",
    "@types/pg": "^8.20.0",
    "aws-sdk-client-mock": "^4.1.0",
    "drizzle-kit": "^0.31.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.3.3"
  },
  "optionalDependencies": {
    "@google/generative-ai": "^0.24.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "openai": "^4.77.0"
  }
}
